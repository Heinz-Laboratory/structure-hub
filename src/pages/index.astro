---
import Base from '../layouts/Base.astro';
import registry from '../data/structure-registry.json';

const projects = [...new Set(registry.map(s => s.project))];
---

<Base title="Structure Hub — Heinz Lab">
  <div class="gallery-wrap">

    <!-- Hero -->
    <div class="gallery-hero">
      <h1 class="hero-title">Structure Hub</h1>
      <p class="hero-sub">
        Interactive 3D molecular structures from the Heinz Interfaces Laboratory.
        Every structure is shareable via URL — rotate, zoom, inspect in your browser.
      </p>
    </div>

    <!-- Search + Filters -->
    <div class="filter-row">
      <div class="search-wrap">
        <svg class="search-icon" width="15" height="15" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.7"/>
          <path d="M13 13l3.5 3.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
        <input
          id="search"
          type="search"
          placeholder="Search structures..."
          autocomplete="off"
          oninput="filterStructures()"
        />
      </div>

      <div class="filter-scroll scroll-x">
        <div class="filter-inner">
          <button class="filter-btn active" data-project="all" onclick="setProject('all', this)">
            All
          </button>
          {projects.map(p => (
            <button class="filter-btn" data-project={p} onclick={`setProject('${p}', this)`}>
              {p}
            </button>
          ))}
        </div>
      </div>

      <span id="count" class="result-count">{registry.length} structures</span>
    </div>

    <!-- Grid -->
    <div id="structure-grid" class="structure-grid">
      {registry.map(s => (
        <a
          href={`/${s.id}`}
          class="structure-card"
          data-project={s.project}
          data-name={s.name.toLowerCase()}
          data-formula={s.formula.toLowerCase()}
          data-tags={(s.tags || []).join(' ')}
        >
          <!-- Thumbnail placeholder -->
          <div class="card-thumb">
            <svg width="44" height="44" viewBox="0 0 48 48" fill="none" opacity="0.25" aria-hidden="true">
              <circle cx="24" cy="24" r="8" fill="#6366f1"/>
              <circle cx="8" cy="12" r="5" fill="#818cf8"/>
              <circle cx="40" cy="12" r="5" fill="#818cf8"/>
              <circle cx="8" cy="36" r="5" fill="#818cf8"/>
              <circle cx="40" cy="36" r="5" fill="#818cf8"/>
              <line x1="24" y1="16" x2="10" y2="13.5" stroke="#4f46e5" stroke-width="2"/>
              <line x1="24" y1="16" x2="38" y2="13.5" stroke="#4f46e5" stroke-width="2"/>
              <line x1="24" y1="32" x2="10" y2="34.5" stroke="#4f46e5" stroke-width="2"/>
              <line x1="24" y1="32" x2="38" y2="34.5" stroke="#4f46e5" stroke-width="2"/>
            </svg>
            <span class="card-format">{s.format.toUpperCase()}</span>
          </div>

          <div class="card-body">
            <div class="card-top">
              <h2 class="card-name" set:html={s.name.replace(/[₀₁₂₃₄₅₆₇₈₉]/g, d => `<sub>${d}</sub>`).replace(/₂/g,'<sub>2</sub>').replace(/₄/g,'<sub>4</sub>').replace(/₃/g,'<sub>3</sub>')} />
              <span class="tag project">{s.project}</span>
            </div>

            <div class="card-formula">{s.formula}</div>

            {s.notes && (
              <p class="card-notes">{s.notes}</p>
            )}

            <div class="card-footer">
              <div class="card-tags">
                {(s.tags || []).slice(0, 3).map(t => (
                  <span class="tag">{t}</span>
                ))}
              </div>
              <span class="card-date">{s.date}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="empty-state" style="display: none;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" opacity="0.25" aria-hidden="true">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.5"/>
        <path d="M16 16l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M8 11h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <p>No structures match your search.</p>
    </div>
  </div>
</Base>

<style>
  /* ---- Gallery wrapper ---- */
  .gallery-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.75rem 1rem 4rem;
  }

  @media (min-width: 640px) {
    .gallery-wrap { padding: 2.5rem 1.5rem 4rem; }
  }

  @media (min-width: 1024px) {
    .gallery-wrap { padding: 3rem 2rem 4rem; }
  }

  /* ---- Hero ---- */
  .gallery-hero {
    margin-bottom: 2rem;
  }

  .hero-title {
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.6rem;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }

  @media (min-width: 640px) {
    .hero-title { font-size: 2rem; }
  }

  .hero-sub {
    color: var(--muted);
    font-size: 0.9rem;
    margin: 0;
    max-width: 520px;
    line-height: 1.65;
  }

  /* ---- Filter row ---- */
  .filter-row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 640px) {
    .filter-row {
      flex-direction: row;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
  }

  /* Search */
  .search-wrap {
    position: relative;
    flex-shrink: 0;
  }

  .search-icon {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    pointer-events: none;
  }

  #search {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.55rem 0.875rem 0.55rem 2rem;
    border-radius: 8px;
    font-size: 0.875rem;
    width: 100%;
    min-height: 40px;
    outline: none;
    font-family: inherit;
    transition: border-color 0.15s;
    -webkit-appearance: none;
    appearance: none;
  }

  #search:focus {
    border-color: var(--accent);
  }

  @media (min-width: 640px) {
    .search-wrap { width: 220px; }
    #search { width: 220px; }
  }

  /* Filter chips */
  .filter-scroll {
    flex: 1;
  }

  .filter-inner {
    display: flex;
    gap: 0.4rem;
    white-space: nowrap;
  }

  .filter-btn {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 0.4rem 0.9rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
    white-space: nowrap;
    min-height: 36px;
    flex-shrink: 0;
  }

  .filter-btn.active,
  .filter-btn:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  /* Count */
  .result-count {
    font-size: 0.8rem;
    color: var(--muted);
    flex-shrink: 0;
    align-self: center;
  }

  @media (max-width: 639px) {
    .result-count { display: none; }
  }

  /* ---- Structure grid ---- */
  .structure-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 500px) {
    .structure-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 900px) {
    .structure-grid { grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  }

  /* ---- Structure card ---- */
  .structure-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .structure-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px rgba(99, 102, 241, 0.2);
    color: inherit;
  }

  .card-thumb {
    background: var(--surface2);
    height: 110px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    flex-shrink: 0;
  }

  .card-format {
    position: absolute;
    bottom: 7px;
    right: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .card-body {
    padding: 1rem 1.125rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.3rem;
  }

  .card-name {
    font-size: 0.9rem;
    font-weight: 600;
    margin: 0;
    color: var(--text);
    line-height: 1.3;
    flex: 1;
    min-width: 0;
  }

  .card-formula {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--accent);
    margin-bottom: 0.4rem;
  }

  .card-notes {
    font-size: 0.78rem;
    color: var(--muted);
    margin: 0 0 0.6rem;
    line-height: 1.45;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .card-tags {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .card-date {
    font-size: 0.7rem;
    color: var(--muted);
    flex-shrink: 0;
  }

  /* ---- Empty state ---- */
  .empty-state {
    text-align: center;
    padding: 4rem 0;
    color: var(--muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .empty-state p {
    font-size: 0.95rem;
    margin: 0;
  }
</style>

<script>
  let currentProject = 'all';
  let currentSearch = '';

  function filterStructures() {
    const searchEl = document.getElementById('search') as HTMLInputElement;
    currentSearch = searchEl?.value.toLowerCase() || '';
    applyFilters();
  }

  function setProject(project: string, btn: HTMLElement) {
    currentProject = project;
    document.querySelectorAll('.filter-btn').forEach(b => {
      const el = b as HTMLElement;
      el.classList.toggle('active', el.dataset.project === project);
    });
    applyFilters();
  }

  function applyFilters() {
    const cards = document.querySelectorAll('.structure-card');
    let visible = 0;
    cards.forEach(card => {
      const el = card as HTMLElement;
      const matchProject = currentProject === 'all' || el.dataset.project === currentProject;
      const searchable = `${el.dataset.name} ${el.dataset.formula} ${el.dataset.tags}`;
      const matchSearch = !currentSearch || searchable.includes(currentSearch);
      const show = matchProject && matchSearch;
      el.style.display = show ? 'flex' : 'none';
      if (show) visible++;
    });
    const countEl = document.getElementById('count');
    if (countEl) countEl.textContent = `${visible} structure${visible !== 1 ? 's' : ''}`;
    const emptyEl = document.getElementById('empty-state');
    if (emptyEl) emptyEl.style.display = visible === 0 ? 'flex' : 'none';
  }

  (window as any).filterStructures = filterStructures;
  (window as any).setProject = setProject;
</script>
