---
import Base from '../layouts/Base.astro';
import registry from '../data/structure-registry.json';

const projects = [...new Set(registry.map(s => s.project))];
---

<Base title="Structure Hub — Heinz Lab">
  <div style="max-width: 1200px; margin: 0 auto; padding: 3rem 2rem 4rem;">

    <!-- Hero -->
    <div style="margin-bottom: 3rem;">
      <h1 style="font-size: 2rem; font-weight: 600; color: var(--text); margin: 0 0 0.75rem; letter-spacing: -0.03em;">
        Structure Hub
      </h1>
      <p style="color: var(--muted); font-size: 1rem; margin: 0; max-width: 520px; line-height: 1.6;">
        Interactive 3D molecular structures from the Heinz Interfaces Laboratory.
        Every structure is shareable via URL — rotate, zoom, inspect in your browser.
      </p>
    </div>

    <!-- Filters + Search -->
    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap;">
      <input
        id="search"
        type="text"
        placeholder="Search structures..."
        style="background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 0.5rem 1rem; border-radius: 8px; font-size: 0.875rem; width: 220px; outline: none;"
        oninput="filterStructures()"
      />
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;" id="project-filters">
        <button class="filter-btn active" data-project="all" onclick="setProject('all', this)" style="background: var(--accent); border: none; color: white; padding: 0.4rem 1rem; border-radius: 6px; font-size: 0.8rem; cursor: pointer; font-family: inherit;">
          All
        </button>
        {projects.map(p => (
          <button class="filter-btn" data-project={p} onclick={`setProject('${p}', this)`} style="background: var(--surface); border: 1px solid var(--border); color: var(--muted); padding: 0.4rem 1rem; border-radius: 6px; font-size: 0.8rem; cursor: pointer; font-family: inherit; transition: all 0.15s;">
            {p}
          </button>
        ))}
      </div>
      <span id="count" style="margin-left: auto; font-size: 0.8rem; color: var(--muted);">{registry.length} structures</span>
    </div>

    <!-- Grid -->
    <div id="structure-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem;">
      {registry.map(s => (
        <a
          href={`/${s.id}`}
          class="structure-card"
          data-project={s.project}
          data-name={s.name.toLowerCase()}
          data-formula={s.formula.toLowerCase()}
          data-tags={(s.tags || []).join(' ')}
          style="display: block; background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 1.25rem 1.5rem; color: inherit; text-decoration: none; transition: border-color 0.15s, box-shadow 0.15s;"
          onmouseover="this.style.borderColor='var(--accent)'; this.style.boxShadow='0 0 0 1px rgba(99,102,241,0.2)';"
          onmouseout="this.style.borderColor='var(--border)'; this.style.boxShadow='none';"
        >
          <!-- Mini preview placeholder -->
          <div style="background: var(--surface2); border-radius: 8px; height: 120px; margin-bottom: 1rem; display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative;">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" opacity="0.3">
              <circle cx="24" cy="24" r="8" fill="#6366f1"/>
              <circle cx="8" cy="12" r="5" fill="#818cf8"/>
              <circle cx="40" cy="12" r="5" fill="#818cf8"/>
              <circle cx="8" cy="36" r="5" fill="#818cf8"/>
              <circle cx="40" cy="36" r="5" fill="#818cf8"/>
              <line x1="24" y1="16" x2="10" y2="13.5" stroke="#4f46e5" stroke-width="2"/>
              <line x1="24" y1="16" x2="38" y2="13.5" stroke="#4f46e5" stroke-width="2"/>
              <line x1="24" y1="32" x2="10" y2="34.5" stroke="#4f46e5" stroke-width="2"/>
              <line x1="24" y1="32" x2="38" y2="34.5" stroke="#4f46e5" stroke-width="2"/>
            </svg>
            <span style="position: absolute; bottom: 8px; right: 10px; font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--muted);">{s.format.toUpperCase()}</span>
          </div>

          <div style="margin-bottom: 0.5rem; display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem;">
            <h2 style="font-size: 0.95rem; font-weight: 600; margin: 0; color: var(--text); line-height: 1.3;" set:html={s.name.replace(/₂/g,'<sub>2</sub>').replace(/₄/g,'<sub>4</sub>').replace(/₃/g,'<sub>3</sub>')} />
            <span class="tag project" style="flex-shrink: 0; margin-top: 2px;">{s.project}</span>
          </div>

          <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: var(--accent); margin-bottom: 0.5rem;">{s.formula}</div>

          {s.notes && (
            <p style="font-size: 0.8rem; color: var(--muted); margin: 0 0 0.75rem; line-height: 1.4; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
              {s.notes}
            </p>
          )}

          <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 0.5rem;">
            <div style="display: flex; gap: 0.35rem; flex-wrap: wrap;">
              {(s.tags || []).slice(0, 3).map(t => (
                <span class="tag">{t}</span>
              ))}
            </div>
            <span style="font-size: 0.75rem; color: var(--muted);">{s.date}</span>
          </div>
        </a>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" style="display: none; text-align: center; padding: 4rem 0; color: var(--muted);">
      <p style="font-size: 0.95rem;">No structures match your search.</p>
    </div>
  </div>
</Base>

<script>
  let currentProject = 'all';
  let currentSearch = '';

  function filterStructures() {
    const searchEl = document.getElementById('search') as HTMLInputElement;
    currentSearch = searchEl?.value.toLowerCase() || '';
    applyFilters();
  }

  function setProject(project: string, btn: HTMLElement) {
    currentProject = project;
    document.querySelectorAll('.filter-btn').forEach(b => {
      const el = b as HTMLElement;
      if (el.dataset.project === project) {
        el.style.background = 'var(--accent)';
        el.style.color = 'white';
        el.style.borderColor = 'var(--accent)';
      } else {
        el.style.background = 'var(--surface)';
        el.style.color = 'var(--muted)';
        el.style.borderColor = 'var(--border)';
      }
    });
    applyFilters();
  }

  function applyFilters() {
    const cards = document.querySelectorAll('.structure-card');
    let visible = 0;
    cards.forEach(card => {
      const el = card as HTMLElement;
      const matchProject = currentProject === 'all' || el.dataset.project === currentProject;
      const searchable = `${el.dataset.name} ${el.dataset.formula} ${el.dataset.tags}`;
      const matchSearch = !currentSearch || searchable.includes(currentSearch);
      const show = matchProject && matchSearch;
      el.style.display = show ? 'block' : 'none';
      if (show) visible++;
    });
    const countEl = document.getElementById('count');
    if (countEl) countEl.textContent = `${visible} structure${visible !== 1 ? 's' : ''}`;
    const emptyEl = document.getElementById('empty-state');
    if (emptyEl) emptyEl.style.display = visible === 0 ? 'block' : 'none';
  }

  // Make functions global
  (window as any).filterStructures = filterStructures;
  (window as any).setProject = setProject;
</script>
